{
  "openapi": "3.1.0",
  "info": {
    "title": "sprinklerGo API",
    "description": "REST-API der sprinklerGo-Bewässerungssteuerung (Go-Port von sprinklers_pi). Zonen- und Programm-IDs sind 0-basierte Indizes; Startzeiten sind Minuten seit lokaler Mitternacht; Laufzeiten sind Minuten (0-255).",
    "version": "1.0.0",
    "license": { "name": "GPL-2.0", "identifier": "GPL-2.0-only" }
  },
  "paths": {
    "/api/state": {
      "get": {
        "summary": "Systemstatus",
        "operationId": "getState",
        "responses": {
          "200": {
            "description": "Aktueller Status",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/State" } } }
          }
        }
      }
    },
    "/api/zones": {
      "get": {
        "summary": "Zonenliste inkl. Live-Zustand",
        "operationId": "getZones",
        "responses": {
          "200": {
            "description": "Alle Zonen",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "zones": { "type": "array", "items": { "$ref": "#/components/schemas/Zone" } },
                    "pumpOn": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/zones/{id}": {
      "put": {
        "summary": "Zone ändern",
        "operationId": "updateZone",
        "parameters": [{ "$ref": "#/components/parameters/id" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ZoneInput" } } }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/Ok" },
          "400": { "$ref": "#/components/responses/Error" },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/zones/{id}/manual": {
      "post": {
        "summary": "Zone manuell an/aus",
        "operationId": "manualZone",
        "parameters": [{ "$ref": "#/components/parameters/id" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["on"],
                "properties": {
                  "on": { "type": "boolean" },
                  "minutes": {
                    "type": "integer", "minimum": 0, "maximum": 1440,
                    "description": "Laufzeitbegrenzung; weggelassen = Einstellung manualTimerMinutes, 0 = unbegrenzt"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/Ok" },
          "400": { "$ref": "#/components/responses/Error" },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/schedules": {
      "get": {
        "summary": "Programmliste inkl. nächster Läufe",
        "operationId": "getSchedules",
        "responses": {
          "200": {
            "description": "Alle Programme",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "schedules": { "type": "array", "items": { "$ref": "#/components/schemas/Schedule" } }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Programm anlegen",
        "operationId": "createSchedule",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ScheduleInput" } } }
        },
        "responses": {
          "201": {
            "description": "Angelegt",
            "content": {
              "application/json": {
                "schema": { "type": "object", "properties": { "id": { "type": "integer" } } }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/schedules/{id}": {
      "get": {
        "summary": "Einzelnes Programm",
        "operationId": "getSchedule",
        "parameters": [{ "$ref": "#/components/parameters/id" }],
        "responses": {
          "200": {
            "description": "Programm",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Schedule" } } }
          },
          "404": { "$ref": "#/components/responses/Error" }
        }
      },
      "put": {
        "summary": "Programm ändern",
        "operationId": "updateSchedule",
        "parameters": [{ "$ref": "#/components/parameters/id" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ScheduleInput" } } }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/Ok" },
          "400": { "$ref": "#/components/responses/Error" },
          "404": { "$ref": "#/components/responses/Error" }
        }
      },
      "delete": {
        "summary": "Programm löschen (nachfolgende IDs rücken auf)",
        "operationId": "deleteSchedule",
        "parameters": [{ "$ref": "#/components/parameters/id" }],
        "responses": {
          "200": { "$ref": "#/components/responses/Ok" },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/quickrun": {
      "post": {
        "summary": "Schnellstart: bestehendes Programm sofort ODER Ad-hoc-Laufzeiten",
        "description": "Genau eines der Felder scheduleId/durations angeben. Ein Programmstart wendet saisonale und Wetter-Anpassung an; Ad-hoc-Laufzeiten laufen unangepasst.",
        "operationId": "quickRun",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "scheduleId": { "type": "integer" },
                  "durations": { "type": "array", "items": { "type": "integer", "minimum": 0, "maximum": 255 } }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/Ok" },
          "400": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/rain-delay": {
      "put": {
        "summary": "Regenpause setzen oder aufheben",
        "description": "Unterdrückt Programmstarts für die angegebene Dauer; manuelle Läufe und Schnellstarts sind nicht betroffen. hours=0 hebt die Pause auf. Überlebt einen Neustart.",
        "operationId": "setRainDelay",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["hours"],
                "properties": { "hours": { "type": "integer", "minimum": 0, "maximum": 336 } }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Gesetzt",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "rainDelayUntil": { "type": "integer", "description": "Unix-Sekunden, 0 = keine Pause" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/events": {
      "get": {
        "summary": "Live-Statusstrom (Server-Sent Events)",
        "description": "Sendet 'event: state' mit dem State-Objekt als data bei jeder Änderung sowie mindestens alle 5 Sekunden.",
        "operationId": "streamEvents",
        "responses": {
          "200": {
            "description": "SSE-Strom",
            "content": { "text/event-stream": { "schema": { "type": "string" } } }
          }
        }
      }
    },
    "/api/auth": {
      "get": {
        "summary": "Auth-Status (immer erreichbar)",
        "operationId": "getAuth",
        "responses": {
          "200": {
            "description": "Status; Token-Liste nur für angemeldete Aufrufer",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "enabled": { "type": "boolean" },
                    "loggedIn": { "type": "boolean" },
                    "hasPassword": { "type": "boolean" },
                    "tokens": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": { "type": "string" },
                          "createdAt": { "type": "integer" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Anmeldung aktivieren/deaktivieren (Passwort muss gesetzt sein)",
        "operationId": "putAuth",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["enabled"],
                "properties": { "enabled": { "type": "boolean" } }
              }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/Ok" },
          "400": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Anmelden — setzt ein Session-Cookie (30 Tage)",
        "operationId": "login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["password"],
                "properties": { "password": { "type": "string" } }
              }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/Ok" },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "summary": "Abmelden",
        "operationId": "logout",
        "responses": { "200": { "$ref": "#/components/responses/Ok" } }
      }
    },
    "/api/auth/password": {
      "post": {
        "summary": "Passwort setzen oder ändern (invalidiert andere Sitzungen)",
        "operationId": "changePassword",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["new"],
                "properties": {
                  "current": { "type": "string" },
                  "new": { "type": "string", "minLength": 6 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "$ref": "#/components/responses/Ok" },
          "400": { "$ref": "#/components/responses/Error" },
          "401": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/auth/tokens": {
      "post": {
        "summary": "API-Token erzeugen (Klartext nur in dieser Antwort)",
        "description": "Verwendung: Header \"Authorization: Bearer <token>\". Gespeichert wird nur der SHA-256.",
        "operationId": "createToken",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": { "name": { "type": "string" } }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Erzeugt",
            "content": {
              "application/json": {
                "schema": { "type": "object", "properties": { "token": { "type": "string" } } }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/auth/tokens/{name}": {
      "delete": {
        "summary": "API-Token widerrufen",
        "operationId": "deleteToken",
        "parameters": [
          { "name": "name", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "$ref": "#/components/responses/Ok" },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/backup": {
      "get": {
        "summary": "Konfiguration als Datei exportieren",
        "operationId": "getBackup",
        "responses": {
          "200": {
            "description": "config.json als Download (Content-Disposition: attachment)",
            "content": { "application/json": { "schema": { "type": "object" } } }
          }
        }
      }
    },
    "/api/restore": {
      "post": {
        "summary": "Konfiguration aus einer Sicherung wiederherstellen",
        "description": "Ältere Sicherungen werden automatisch migriert und validiert; eine laufende Bewässerung stoppt.",
        "operationId": "postRestore",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object" } } }
        },
        "responses": {
          "200": {
            "description": "Wiederhergestellt",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "restartRequired": { "type": "boolean" },
                    "outputError": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/stop": {
      "post": {
        "summary": "Alles stoppen (Zonen aus, Tagesplan neu aufbauen)",
        "operationId": "stopAll",
        "responses": { "200": { "$ref": "#/components/responses/Ok" } }
      }
    },
    "/api/system/run": {
      "put": {
        "summary": "Scheduler global an/aus",
        "operationId": "setRunSchedules",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["enabled"],
                "properties": { "enabled": { "type": "boolean" } }
              }
            }
          }
        },
        "responses": { "200": { "$ref": "#/components/responses/Ok" } }
      }
    },
    "/api/settings": {
      "get": {
        "summary": "Einstellungen lesen",
        "operationId": "getSettings",
        "responses": {
          "200": {
            "description": "Einstellungen",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Settings" } } }
          }
        }
      },
      "put": {
        "summary": "Einstellungen ersetzen (vollständiges Objekt)",
        "operationId": "updateSettings",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Settings" } } }
        },
        "responses": {
          "200": {
            "description": "Gespeichert",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "restartRequired": { "type": "boolean", "description": "true, wenn der Web-Port geändert wurde" },
                    "outputError": { "type": "string", "description": "gesetzt, wenn das Hardware-Backend nicht initialisiert werden konnte" }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/weather/check": {
      "get": {
        "summary": "Wetter-Diagnose: Provider abfragen und Skalierung berechnen",
        "operationId": "weatherCheck",
        "responses": {
          "200": {
            "description": "Diagnoseergebnis",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WeatherCheck" } } }
          }
        }
      }
    },
    "/api/logs": {
      "get": {
        "summary": "Bewässerungsverlauf (roh oder gruppiert)",
        "operationId": "getLogs",
        "parameters": [
          {
            "name": "group", "in": "query",
            "schema": { "type": "string", "enum": ["none", "hour", "day", "month"], "default": "none" },
            "description": "day gruppiert nach Wochentag (0 = Sonntag), month nach Monat (1-12)"
          },
          { "name": "start", "in": "query", "schema": { "type": "integer" }, "description": "Unix-Sekunden (Default: jetzt - 7 Tage)" },
          { "name": "end", "in": "query", "schema": { "type": "integer" }, "description": "Unix-Sekunden (Default: jetzt)" }
        ],
        "responses": {
          "200": {
            "description": "group=none liefert entries, sonst series",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "group": { "type": "string" },
                    "entries": { "type": "array", "items": { "$ref": "#/components/schemas/LogEntry" } },
                    "series": { "type": "array", "items": { "$ref": "#/components/schemas/ZoneSeries" } }
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Error" }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "id": {
        "name": "id", "in": "path", "required": true,
        "schema": { "type": "integer", "minimum": 0 },
        "description": "0-basierter Index"
      }
    },
    "responses": {
      "Ok": {
        "description": "Erfolg",
        "content": {
          "application/json": {
            "schema": { "type": "object", "properties": { "ok": { "type": "boolean" } } }
          }
        }
      },
      "Error": {
        "description": "Fehler",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "required": ["error"],
              "properties": { "error": { "type": "string" } }
            }
          }
        }
      }
    },
    "schemas": {
      "State": {
        "type": "object",
        "properties": {
          "version": { "type": "string" },
          "time": { "type": "integer", "description": "Unix-Sekunden" },
          "schedulerEnabled": { "type": "boolean" },
          "mode": { "type": "string", "enum": ["idle", "schedule", "manual"] },
          "zoneId": { "type": "integer", "description": "-1 = keine aktive Zone" },
          "zoneName": { "type": "string" },
          "scheduleId": { "type": "integer", "description": "-1 = keines, 99 = Schnellstart" },
          "scheduleName": { "type": "string" },
          "remainingSeconds": { "type": "integer", "description": "-1 = unbegrenzt (manuell)" },
          "pendingEvents": { "type": "integer" },
          "enabledZones": { "type": "integer" },
          "scheduleCount": { "type": "integer" },
          "rainDelayUntil": { "type": "integer", "description": "Unix-Sekunden, 0 = keine Regenpause" },
          "clock24h": { "type": "boolean" },
          "zonesOn": { "type": "array", "items": { "type": "boolean" } },
          "pumpOn": { "type": "boolean" },
          "planned": {
            "type": "array",
            "description": "Heute noch anstehende Programmstarts",
            "items": {
              "type": "object",
              "properties": {
                "scheduleId": { "type": "integer" },
                "scheduleName": { "type": "string" },
                "at": { "type": "integer", "description": "Unix-Sekunden" }
              }
            }
          },
          "queue": {
            "type": "array",
            "description": "Zonenfolge des aktiven Programmlaufs",
            "items": {
              "type": "object",
              "properties": {
                "zoneId": { "type": "integer" },
                "zoneName": { "type": "string" },
                "start": { "type": "integer" },
                "end": { "type": "integer" },
                "done": { "type": "boolean" },
                "active": { "type": "boolean" }
              }
            }
          },
          "weather": {
            "type": "object",
            "description": "Zwischengespeicherte Wetterdaten (stündlich aktualisiert)",
            "properties": {
              "provider": { "type": "string" },
              "scale": { "type": "integer" },
              "valid": { "type": "boolean" },
              "fetchedAt": { "type": "integer", "description": "Unix-Sekunden, 0 = nie" }
            }
          }
        }
      },
      "Zone": {
        "allOf": [
          { "$ref": "#/components/schemas/ZoneInput" },
          {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "on": { "type": "boolean", "description": "läuft gerade" }
            }
          }
        ]
      },
      "ZoneInput": {
        "type": "object",
        "required": ["name", "enabled", "pump"],
        "properties": {
          "name": { "type": "string", "maxLength": 50 },
          "enabled": { "type": "boolean" },
          "pump": { "type": "boolean", "description": "Pumpe/Masterventil (Ausgang 0) mitschalten" }
        }
      },
      "Schedule": {
        "allOf": [
          { "$ref": "#/components/schemas/ScheduleInput" },
          {
            "type": "object",
            "properties": {
              "id": { "type": "integer" },
              "nextRun": {
                "oneOf": [{ "$ref": "#/components/schemas/NextRun" }, { "type": "null" }]
              }
            }
          }
        ]
      },
      "ScheduleInput": {
        "type": "object",
        "required": ["name", "enabled", "kind"],
        "properties": {
          "name": { "type": "string", "maxLength": 50 },
          "enabled": { "type": "boolean" },
          "kind": { "type": "string", "enum": ["weekly", "interval"] },
          "days": {
            "type": "array", "items": { "type": "boolean" }, "minItems": 7, "maxItems": 7,
            "description": "Index 0 = Sonntag; nur bei kind=weekly"
          },
          "interval": { "type": "integer", "minimum": 1, "maximum": 365, "description": "alle N Tage; nur bei kind=interval" },
          "restriction": { "type": "integer", "enum": [0, 1, 2], "description": "0 = keine, 1 = ungerade Monatstage, 2 = gerade" },
          "weatherAdjust": { "type": "boolean" },
          "startTimes": {
            "type": "array", "items": { "type": "integer", "minimum": 0, "maximum": 1439 }, "maxItems": 4,
            "description": "Minuten seit Mitternacht"
          },
          "durations": {
            "type": "array", "items": { "type": "integer", "minimum": 0, "maximum": 255 },
            "description": "Minuten je Zone, Index = Zonen-ID; wird serverseitig auf Zonenanzahl aufgefüllt"
          },
          "cycleMaxMinutes": { "type": "integer", "minimum": 0, "maximum": 255, "description": "Zyklus & Sickern: max. Zyklusdauer (0 = aus)" },
          "soakMinutes": { "type": "integer", "minimum": 0, "maximum": 255, "description": "Sickerpause je Zone zwischen ihren Zyklen" }
        }
      },
      "NextRun": {
        "type": "object",
        "properties": {
          "date": { "type": "string", "format": "date" },
          "inDays": { "type": "integer" },
          "times": { "type": "array", "items": { "type": "integer" } }
        }
      },
      "Settings": {
        "type": "object",
        "properties": {
          "webPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
          "outputType": { "type": "string", "enum": ["none", "script", "gpio+", "gpio-"] },
          "scriptPath": { "type": "string", "description": "aufgerufen als \"<pfad> <ausgang> <0|1>\"" },
          "gpioPins": { "type": "array", "items": { "type": "integer" }, "minItems": 16, "maxItems": 16, "description": "BCM-Pins, Index 0 = Pumpe" },
          "seasonalAdjust": { "type": "integer", "minimum": 0, "maximum": 200 },
          "seasonalMode": { "type": "string", "enum": ["global", "monthly"] },
          "seasonalMonthly": { "type": "array", "items": { "type": "integer", "minimum": 0, "maximum": 200 }, "minItems": 12, "maxItems": 12 },
          "pumpPreSeconds": { "type": "integer", "minimum": 0, "maximum": 120, "description": "Pumpen-Vorlauf vor dem Zonenventil" },
          "pumpPostSeconds": { "type": "integer", "minimum": 0, "maximum": 120, "description": "Pumpen-Nachlauf nach dem Zonenventil" },
          "weatherProvider": { "type": "string", "enum": ["none", "openmeteo"] },
          "apiKey": { "type": "string" },
          "apiSecret": { "type": "string" },
